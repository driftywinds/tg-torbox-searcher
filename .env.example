# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# TorBox API key, from https://torbox.app/settings (API key section)
TORBOX_API_KEY=

# GoFile.io API key (currently kept for completeness; TorBox's own
# Integrations API is what actually performs the GoFile upload using the
# GoFile credentials configured on your TorBox account settings)
GOFILE_API_KEY=

# Your numeric Telegram user id. This user is always authorized and is the
# only one who can run /adduser, /removeuser, /listusers.
# Get your id by messaging @userinfobot on Telegram.
ADMIN_TELEGRAM_ID=

# Where to persist the authorized-users list. Defaults to ./data
DATA_DIR=./data

# Advanced / only needed if TorBox changes these:
# TORBOX_API_BASE_URL=https://api.torbox.app/v1/api
# TORBOX_SEARCH_BASE_URL=https://search-api.torbox.app

# --- Search backend ---
# "torznab" (recommended) or "torbox" (default, may be IP-restricted)
# Torznab queries a Jackett or Prowlarr instance.
SEARCH_BACKEND=torznab
TORZNAB_URL=
TORZNAB_API_KEY=
